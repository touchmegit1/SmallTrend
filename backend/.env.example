# ===================================================================
# SmallTrend Backend Environment Variables
# Copy this file to .env and fill values for your local machine.
# ===================================================================

# =========================
# REQUIRED (to run backend)
# =========================
SERVER_PORT=8081

DB_URL=jdbc:mysql://localhost:3306/smalltrend?allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=1234

SPRING_JPA_DDL_AUTO=update
SPRING_SQL_INIT_MODE=never

# Use a strong random secret for production
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRATION=86400000

# ================================
# OPTIONAL (feature specific)
# ================================

# Gemini AI (if missing, backend still starts, but AI chat returns config warning)
GEMINI_API_KEY=

# Cloudinary (required only for image/file upload features)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Legacy / reserved keys (currently not required by active backend config)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smalltrend
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
# Optional override recipients for inventory notify-manager API (comma-separated emails)
APP_NOTIFICATIONS_INVENTORY_MANAGER_RECIPIENTS=

# CORS allowed origins (comma-separated). Add your devtunnel frontend URL here when using devtunnels.
# Example for devtunnels: CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://7qb3wvmd-5173.asse.devtunnels.ms
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000, https://7qb3wvmd-5173.asse.devtunnels.ms/

# Optional recipients for out-of-stock alerts (fallback: active MANAGER accounts)
APP_NOTIFICATIONS_INVENTORY_OUT_OF_STOCK_RECIPIENTS=
# Enable/disable daily out-of-stock summary email
APP_NOTIFICATIONS_INVENTORY_OUT_OF_STOCK_DAILY_ENABLED=true
# Cron for daily summary (default 07:05 every day)
APP_NOTIFICATIONS_INVENTORY_OUT_OF_STOCK_DAILY_CRON=0 05 7 * * *
# Enable/disable daily expired-batch summary email
APP_NOTIFICATIONS_INVENTORY_EXPIRED_BATCH_DAILY_ENABLED=true
# Cron for expired-batch summary (default 07:15 every day)
APP_NOTIFICATIONS_INVENTORY_EXPIRED_BATCH_DAILY_CRON=0 15 7 * * *

UPLOAD_PATH=/uploads
MAX_FILE_SIZE=10MB